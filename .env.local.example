# Copy this file to .env.local and fill in your values
# Gemini API Key - Get from https://ai.google.dev
NEXT_PUBLIC_GEMINI_API_KEY=your_api_key_here

# App Configuration
NEXT_PUBLIC_APP_NAME=Meddy
NEXT_PUBLIC_APP_VERSION=1.0.0

# Optional: Cerebras rotated keys
NEXT_PUBLIC_CEREBRAS_API_1=your_cerebras_key_1
NEXT_PUBLIC_CEREBRAS_API_2=your_cerebras_key_2
NEXT_PUBLIC_CEREBRAS_API_3=your_cerebras_key_3
NEXT_PUBLIC_CEREBRAS_API_4=your_cerebras_key_4
NEXT_PUBLIC_CEREBRAS_API_5=your_cerebras_key_5
NEXT_PUBLIC_CEREBRAS_API_6=your_cerebras_key_6

# Optional: Groq rotated keys for server-side proxying
# Set these in Vercel Environment Variables and your local .env.local.
GROQ_API_1=your_groq_key_1
GROQ_API_2=your_groq_key_2
GROQ_API_3=your_groq_key_3
GROQ_API_4=your_groq_key_4
GROQ_API_5=your_groq_key_5
GROQ_API_6=your_groq_key_6
GROQ_API_7=your_groq_key_7
